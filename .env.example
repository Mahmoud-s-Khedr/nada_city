# ============================================================
# Environment Configuration
# Copy this file to .env and update with your values
# ============================================================

# Application
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nada_city?schema=public"

# Authentication
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
ACCESS_TOKEN_TTL="15m"

# Redis / Valkey
# Used for refresh token storage (supports multi-device sessions).
REDIS_URL="redis://localhost:6379"

# CORS
# Use an explicit origin when sending credentials from browsers
# (cookies or Authorization header). Example: http://localhost:5173
CORS_ORIGIN="*"

# Logging
LOG_LEVEL="info"

# Rate Limiting
RATE_LIMIT_MAX=100

# S3-Compatible Storage
# Use MinIO endpoint in dev (docker-compose) and Cloudflare R2 in production
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_BUCKET="nada-city-uploads"
S3_FORCE_PATH_STYLE="true"

# Email (Resend — production only)
RESEND_API_KEY=""
FROM_EMAIL="noreply@nada.city"
