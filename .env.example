# ============================================================
# Environment Configuration
# Copy this file to .env and update with your values
# ============================================================

# Application
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
# These MUST be set when using docker-compose. They initialize the Postgres
# container AND are injected into the app's DATABASE_URL inside Docker.
# WARNING: Changing these after the first run requires wiping the pgdata volume
# (docker volume rm nada_city_pgdata) because Postgres bakes the password into
# the data directory on initialization.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DB_PORT=5432

# DATABASE_URL is used for local dev (running Node outside Docker).
# Inside docker-compose it is overridden automatically to use the `db` hostname.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nada_city?schema=public"

# Authentication
# Minimum 32 characters. Generate one with: openssl rand -base64 32
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
ACCESS_TOKEN_TTL="15m"

# Redis / Valkey
# Used for refresh token storage (supports multi-device sessions).
REDIS_URL="redis://localhost:6379"
REDIS_PORT=6379

# CORS
# Use an explicit origin when sending credentials from browsers
# (cookies or Authorization header). Example: http://localhost:5173
CORS_ORIGIN="*"

# Logging
LOG_LEVEL="info"

# Rate Limiting
RATE_LIMIT_MAX=100

# S3-Compatible Storage (MinIO in dev, Cloudflare R2 in production)
# MinIO root credentials used by docker-compose to create the MinIO server & bucket.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=nada-city-uploads
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_BUCKET="nada-city-uploads"
S3_FORCE_PATH_STYLE="true"

# Email (Resend — production only)
RESEND_API_KEY=""
FROM_EMAIL="noreply@nada.city"
