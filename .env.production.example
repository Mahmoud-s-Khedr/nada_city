# Application
NODE_ENV=production
COMPOSE_NGINX_PORT=8080

# Public API / browser origin
CORS_ORIGIN=https://api.example.com,https://app.example.com

# Authentication
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters-long
ACCESS_TOKEN_TTL=15m

# Logging / limits
LOG_LEVEL=info
RATE_LIMIT_MAX=100

# Host PostgreSQL
DATABASE_URL=postgresql://postgres:change-me@host.docker.internal:5432/nada_city?schema=public

# Compose Redis
REDIS_PORT=6379

# Host MinIO
S3_ENDPOINT=http://host.docker.internal:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=change-me
S3_BUCKET=nada-city-uploads
S3_PUBLIC_BASE_URL=https://minio.example.com/nada-city-uploads
S3_FORCE_PATH_STYLE=true

# Email
RESEND_API_KEY=re_xxxxxxxxx
FROM_EMAIL=noreply@nada.city
